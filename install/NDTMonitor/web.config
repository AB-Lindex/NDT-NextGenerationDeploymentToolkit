<?xml version="1.0" encoding="UTF-8"?>
<!--
  NDT Monitor - IIS web service configuration.

  Deployed to the site physical path by Install-NDTMonitor.
  The LogRoot appSetting below is rewritten by Install-NDTMonitor to the
  actual progress-log folder (default: <LocalPath>\Logs\progress).

  Endpoint:
    POST /progress          receive a progress update (JSON body)
    GET  /progress          return all machine states as a JSON array
    GET  /progress?mac=..   return a single machine's latest state

  The handler type NDTMonitor.ProgressHandler lives in App_Code and is
  compiled automatically by ASP.NET - no separate build step is required.
-->
<configuration>
  <appSettings>
    <add key="LogRoot" value="C:\Deploy2026\Logs\progress" />
  </appSettings>
  <system.web>
    <compilation debug="false" targetFramework="4.5" />
    <httpRuntime targetFramework="4.5" />
    <customErrors mode="RemoteOnly" />
  </system.web>
  <system.webServer>
    <handlers>
      <!-- Map the extensionless path /progress to the managed handler in App_Code -->
      <add name="NDTProgress" path="progress" verb="*"
           type="NDTMonitor.ProgressHandler"
           resourceType="Unspecified" preCondition="integratedMode" />
    </handlers>
    <directoryBrowse enabled="false" />
    <defaultDocument>
      <files>
        <clear />
        <add value="Default.htm" />
      </files>
    </defaultDocument>
  </system.webServer>
</configuration>
